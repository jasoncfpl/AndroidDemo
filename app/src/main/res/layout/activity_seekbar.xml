<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:padding="32dp"
    android:background="#292937"
    android:gravity="center">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/accompany_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:layout_gravity="center_vertical"
                android:text="伴奏"
                android:textColor="@android:color/white"
                android:textSize="14sp" />

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp">

                <TextView
                    android:id="@+id/accompany_progress"
                    android:layout_width="40dp"
                    android:layout_height="28dp"
                    android:paddingTop="2dp"
                    android:background="@mipmap/bg_seek_bar_progress"
                    android:gravity="center_horizontal"
                    android:minHeight="28dp"
                    android:text="10"
                    android:textColor="@android:color/black"
                    android:textSize="12sp" />

                <SeekBar
                    android:id="@+id/accompany"
                    android:layout_width="match_parent"
                    android:layout_height="25dp"
                    android:layout_below="@+id/accompany_progress"
                    android:layout_gravity="center_vertical"
                    android:maxHeight="3dp"
                    android:minHeight="3dp"
                    android:paddingStart="20dp"
                    android:paddingEnd="25dp"
                    android:progressDrawable="@drawable/eq_seekbar_bg"
                    android:splitTrack="false"
                    android:thumb="@drawable/eq_seekbar_thumb"
                    tools:ignore="InefficientWeight,RtlHardcoded"
                    tools:targetApi="lollipop" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_below="@+id/accompany"
                    android:layout_marginStart="12dp"
                    android:text="0"
                    android:textColor="@android:color/darker_gray"
                    android:textSize="12sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_below="@+id/accompany"
                    android:layout_alignParentEnd="true"
                    android:layout_marginEnd="12dp"
                    android:text="100"
                    android:textColor="@android:color/darker_gray"
                    android:textSize="12sp" />

            </RelativeLayout>

        </LinearLayout>

    </LinearLayout>

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:layout_marginTop="100dp">


        <!-- 跟随进度的 View，显示当前进度值 -->
        <TextView
            android:id="@+id/progress_indicator"
            android:layout_width="40dp"
            android:layout_height="wrap_content"
            android:background="@mipmap/bg_seek_bar_progress"
            android:text="0"
            android:minHeight="28dp"
            android:textColor="@android:color/white"
            android:textSize="14sp"
            android:textStyle="bold"
            android:gravity="center"
            android:minWidth="40dp" />

        <!-- SeekBar -->
        <SeekBar
            android:id="@+id/seekbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            android:layout_below="@+id/progress_indicator"
            android:background="@android:color/holo_red_dark"
            android:maxHeight="3dp"
            android:minHeight="3dp"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:progressDrawable="@drawable/eq_seekbar_bg"
            android:splitTrack="false"
            android:thumb="@drawable/eq_seekbar_thumb"
            android:max="100"
            android:progress="0" />


        <com.warkiz.widget.IndicatorSeekBar
            android:id="@+id/indicator_seek_bar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@+id/seekbar"
            android:layout_marginTop="20dp"
            app:isb_max="100"
            app:isb_min="20"
            app:isb_progress="25"
            app:isb_seek_smoothly="true"
            app:isb_show_tick_marks_type="oval"
            app:isb_show_tick_texts="true"
            app:isb_tick_texts_size="15sp"
            app:isb_tick_texts_color="@android:color/holo_blue_dark"
            app:isb_thumb_drawable="@drawable/eq_seekbar_thumb"
            app:isb_thumb_size="20dp"
            app:isb_show_indicator="rounded_rectangle"
            app:isb_indicator_color="#BEFF45"
            app:isb_indicator_text_color="@android:color/white"
            app:isb_indicator_text_size="18sp"
            app:isb_indicator_content_layout="@layout/custom_top_content_view_round_miles"
            app:isb_track_background_color="#1AFFFFFF"
            app:isb_track_background_size="3dp"
            app:isb_track_progress_color="#BEFF45"
            app:isb_track_progress_size="3dp" />

        <com.jason.seekbar.BubbleSeekBar
            android:id="@+id/bubble_seek_bar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@+id/indicator_seek_bar"
            app:bsb_bubble_color="@android:color/holo_red_dark"
            app:bsb_bubble_text_color="@android:color/holo_blue_dark"
            app:bsb_max="100"
            app:bsb_min="20"
            app:bsb_progress="1"
            app:bsb_second_track_color="@android:color/holo_green_light"
            app:bsb_section_count="5"
            app:bsb_section_text_position="bottom_sides"
            app:bsb_show_progress_in_float="true"
            app:bsb_show_section_mark="false"
            app:bsb_show_section_text="true"
            app:bsb_show_thumb_text="true"
            app:bsb_track_color="@android:color/holo_blue_dark"/>


    </RelativeLayout>

</LinearLayout>


